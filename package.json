{
  "name": "factory-platform-ui",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "pnpm -C apps/portal-ui dev",
    "build": "pnpm -C apps/portal-ui build",
    "preview": "pnpm -C apps/portal-ui preview",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=200",
    "status": "bash scripts/dev-status.sh",
    "status:quick": "bash scripts/dev-status.sh quick",
    "status:next": "bash scripts/dev-status.sh next",
    "status:urls": "bash scripts/dev-status.sh urls",
    "status:creds": "bash scripts/dev-status.sh creds"
  }
}
